algoritmo "Divisivel2E3"

var
  numero, resto2, resto3: inteiro
  divisivel: logico

inicio

  escreva("Digite um número inteiro: ")
  leia(numero)
  escreval(numero)
  escreval()

  resto2 <- numero MOD 2
  resto3 <- numero MOD 3
  divisivel <- (resto2 = 0) e (resto3 = 0)

  se (divisivel) entao
    escreval("Sim, é divisível por 2 e por 3")
  senao
    escreval("Não atende às duas condições")
  fimse

fimalgoritmo
