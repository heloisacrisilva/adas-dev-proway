algoritmo "DobroETriplo"

var
  numero: real
  resultadoDobro, resultadoTriplo: real

inicio

  escreva("Insira um número: ")
  leia(numero)
  escreval(numero)

  resultadoDobro <- numero * 2
  resultadoTriplo <- numero * 3

  escreval("O drobro deste número é: " + resultadoDobro)
  escreval("O triplo deste número é: " + resultadoTriplo)

fimalgoritmo
