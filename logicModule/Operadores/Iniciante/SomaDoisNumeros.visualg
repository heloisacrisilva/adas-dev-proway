algoritmo "SomaDoisNumeros"

var
  numero1, numero2: real
  resultado: real

inicio

  escreva("Insira o primeiro número: ")
  leia(numero1)
  escreval(numero1)

  escreva("Insira o segundo número: ")
  leia(numero2)
  escreval(numero2)

  resultado <- numero1 + numero2
  escreval("O resultado da soma é: " + resultado)

fimalgoritmo
