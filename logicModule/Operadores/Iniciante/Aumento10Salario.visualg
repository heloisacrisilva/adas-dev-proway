algoritmo "Aumento10Salario"

var
  salario: real
  aumento: real
  salarioFinal: real

inicio

  aumento <- 0.10

  escreva("Insira o seu salário atual: ")
  leia(salario)
  escreval(salario)

  salarioFinal <- (salario * aumento) + salario

  escreval("Seu salário considerando o aumento de 10% é: " + salarioFinal)

fimalgoritmo
