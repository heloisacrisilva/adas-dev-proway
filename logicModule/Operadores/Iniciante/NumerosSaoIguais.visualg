algoritmo "NumerosSaoIguais"

var
  numero1, numero2: real
  saoIguals: logico

inicio

  escreva("Digite o primeiro número: ")
  leia(numero1)
  escreval(numero1)

  escreva("Digite o segundo número: ")
  leia(numero2)
  escreval(numero2)

  saoIguals <- numero1 = numero2

  escreval("Números são iguais? " + saoIguals)

  // se (numero1 = numero2) entao
  //   escreval("Os números são iguais!")
  // senao 
  //   escreval("Os números não são iguais.")
  // fimse

fimalgoritmo
