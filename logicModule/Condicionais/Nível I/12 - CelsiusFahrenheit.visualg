algoritmo "CelsiusFahrenheit"

var
  temperaturaC, temperaturaF: real
  valida: logico

inicio

  escreva("Informe a temperatura atual(Celsius): ")
  leia(temperaturaC)
  escreval(temperaturaC)

  temperaturaF <- (temperaturaC * 9/5) + 32
  
  escreval()
  escreval(temperaturaF, " Fahrenheit")

fimalgoritmo
