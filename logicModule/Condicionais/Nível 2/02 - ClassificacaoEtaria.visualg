algoritmo "ClassificacaoEtaria"

var
  idade: inteiro

inicio
  escreva("Informe sua idade: ")
  leia(idade)
  escreval(idade)

  se (idade < 0 ) entao
    escreval("Idade inválida.")
  senao
    se (idade <= 12) entao
      escreval("Criança")
    senao
      se (idade <= 17) entao
        escreval("Adolescente")
      senao
        se (idade <= 59) entao
          escreval("Adulto")
        senao
          escreval("Idoso")
        fimse
      fimse
    fimse
  fimse

fimalgoritmo
